{
  "expo": {
    "name": "ダブル特化ダメ計",
    "slug": "double-damage-calc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maaaataku.doublecalc"
    },
    "android": {
      "package": "com.maaaataku.doublecalc",
      "adaptiveIcon": {
        "backgroundColor": "#0A0E16",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "baseUrl": "/PokemonChampions"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E16"
        }
      ]
    ]
  }
}
